# Coston2 proxy config for CipherSign (Flare FCC getting-started aligned).
#
# Copy:
#   cp config/proxy/extension_proxy.coston2.toml.example \
#      config/proxy/extension_proxy.toml
#
# Fill [db] with Flare C-chain indexer credentials from Telegram support.
# Working host used during Summer Signal (confirm if Flare rotates): 34.38.42.208
#
# docker compose mounts this file at /app/config/config.toml

redis_port = "redis:6379"
chain_id = 114
private_key_variable = "PRIVATE_KEY"
initial_signing_policy_offset = 3
signing_policy_fetch_interval = "20s"

[db]
host = "<indexer-db-host>"
port = 3306
database = "indexer"
username = "<indexer-db-user>"
password = "<indexer-db-password>"
log_queries = false

[addresses]
flare_systems_manager = "0xA90Db6D10F856799b10ef2A77EBCbF460aC71e52"
relay = "0xa10B672D1c62e5457b17af63d4302add6A99d7dE"
voter_registry = "0x6a0AF07b7972177B176d3D422555cbc98DfDe914"

[ports]
internal = "6663"
external = "6664"

[info_timing]
cycle_internal = "100s"
cycle_queue_response_wait = "2s"

[voting]
proposal_expiration = "120s"
max_pending_request = 10000

# POST /direct for hackathon demos (bypass waiting on full on-chain roundtrip)
[direct]
enable = true
api_key_variable = "DIRECT_API_KEY"
