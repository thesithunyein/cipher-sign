# CipherSign TEE stack — aligned with Flare FCC getting-started (Jul 2026)
# https://dev.flare.network/fcc/guides/getting-started
#
#   cp .env.example .env

# Language (CipherSign product logic is TypeScript)
LANGUAGE=typescript

# Funded Coston2 private key (hex, no 0x prefix)
# Guide: DEPLOYMENT_PRIVATE_KEY / PROXY_PRIVATE_KEY — same key is fine for hackathon.
PRIVATE_KEY="<your-funded-coston2-private-key>"

# Initial owner address (from PRIVATE_KEY)
INITIAL_OWNER="0x<your-address>"

# Filled by pre-build.sh into config/extension.env (leave placeholders until then)
INSTRUCTION_SENDER="0x<deployed-address>"
EXTENSION_ID="0x<64-hex-chars>"

# Public HTTPS tunnel to host port 6674 (guide Step 2)
#   cloudflared tunnel --url http://localhost:6674
#   ngrok http 6674
# Set BOTH to the same HTTPS URL (scripts accept either name).
EXT_PROXY_URL="https://<your-tunnel-domain>"
TUNNEL_URL="https://<your-tunnel-domain>"

# Optional API key for POST /direct (web live mode)
DIRECT_API_KEY="<generate-a-random-string>"

FEE_WEI=1000000000000
CHAIN_URL=https://coston2-api.flare.network/ext/C/rpc
ADDRESSES_FILE=./config/coston2/deployed-addresses.json
NORMAL_PROXY_URL=https://tee-proxy-coston2-1.flare.rocks

# Required on live Coston2 (guide Step 1)
LOCAL_MODE=false
SIMULATED_TEE=true
CHAIN_ID=114

# Optional governance (defaults to INITIAL_OWNER, threshold 1)
# GOVERNANCE_SIGNERS="0xAbc..."
# GOVERNANCE_THRESHOLD=1

# Docker build branches — must be develop (Flare guide)
TEE_NODE_VERSION=develop
TEE_PROXY_VERSION=develop
